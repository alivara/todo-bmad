# todo-app configuration (12-factor). EVERY value here has a working default baked
# into docker-compose.yml, so `docker compose up` works with NO .env file at all.
# Copy this to `.env` only if you want to override a default. NEVER commit real
# secrets — `.env` is gitignored; this `.env.example` is the tracked documentation.

# --- PostgreSQL (db service) ---
# Local dev credentials only. Change these for any non-local deployment.
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_DB=todo

# --- frontend (the only host-exposed service) ---
# Host port to reach the app at http://localhost:<WEB_PORT>.
WEB_PORT=3000

# --- Notes on internal wiring (set automatically in compose; listed for clarity) ---
# backend reads DATABASE_URL = postgres://<user>:<password>@db:5432/<db>?sslmode=disable
# backend serves on PORT=8080 (internal only)
# frontend reads API_INTERNAL_URL=http://backend:8080 to proxy same-origin /api/* calls
