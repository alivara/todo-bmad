# --- BMAD tooling (installed framework + skills) ---
# Not committed: each developer installs BMAD themselves. We track deliverables only.
.claude/
_bmad/
.bmad-loop/

# --- Personal / machine-local overrides ---
**/settings.local.json
**/*.user.toml
**/*.user.yaml

# --- BMAD ephemeral / working artifacts (not deliverables) ---
**/.memlog.md
_bmad-output/party-mode/
**/.working/

# --- OS / editor cruft ---
.DS_Store

# --- Runtime env (never commit real secrets; .env.example IS tracked) ---
.env
**/.env
!**/.env.example

# --- web (Next.js / Node) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/next-env.d.ts
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

# --- api (Go) ---
backend/bin/
backend/tmp/
*.test
